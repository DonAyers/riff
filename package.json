{
  "name": "riff",
  "version": "2.0.1",
  "description": "Record a riff, chord, or arpeggio — see every note you played.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "readme:image": "playwright test --config=playwright.readme.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "release:check": "npm run test && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@spotify/basic-pitch": "^1.0.1",
    "@tensorflow/tfjs": "^4.22.0",
    "@tonaljs/chord": "^6.1.2",
    "idb": "^8.0.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "smplr": "^0.18.1",
    "svguitar": "^2.5.1",
    "tonal": "^6.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
